{
  "version": 2,
  "installCommand": "npm --prefix resume-generator-api install && npm --prefix resume-generator-ui install",
  "buildCommand": "npm --prefix resume-generator-ui run build",
  "outputDirectory": "resume-generator-ui/dist",
  "functions": {
    "resume-generator-api/server.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/resume-generator-api/server.js" },
    { "source": "/helo", "destination": "/resume-generator-api/server.js" },
    { "source": "/uploads/:path*", "destination": "/resume-generator-api/server.js" }
  ]
}
