{
  "version": 2,
  "installCommand": "npm --prefix resume-generator-api install && npm --prefix resume-generator-ui install",
  "buildCommand": "npm --prefix resume-generator-ui run build",
  "outputDirectory": "resume-generator-ui/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/helo", "destination": "/api/index.js" },
    { "source": "/uploads/:path*", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
